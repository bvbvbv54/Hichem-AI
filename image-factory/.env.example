# ─── Application ──────────────────────────────────────────
APP_NAME=ImageFactory
APP_VERSION=1.0.0
APP_ENV=production
DEBUG=false
SECRET_KEY=change-me-to-a-random-secret-string

# ─── API ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_KEY=image-factory-api-key-change-me
API_RATE_LIMIT=100
API_RATE_LIMIT_PERIOD=60

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://imagefactory:imagefactory@postgres:5432/imagefactory
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_BROKER_URL=redis://redis:6379/1

# ─── Claude ──────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-change-me
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7

# ─── Nano Banana / Image Provider ────────────────────────
# Supported providers: replicate, stabilityai, openai
IMAGE_PROVIDER=replicate
IMAGE_PROVIDER_API_KEY=change-me
IMAGE_PROVIDER_TIMEOUT=120
IMAGE_PROVIDER_MAX_RETRIES=3
IMAGE_PROVIDER_POLL_INTERVAL=2

# Replicate specific
REPLICATE_API_KEY=change-me

# StabilityAI specific
STABILITYAI_API_KEY=change-me

# OpenAI specific
OPENAI_API_KEY=change-me

# ─── Storage ─────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./outputs
STORAGE_S3_BUCKET=change-me
STORAGE_S3_ACCESS_KEY=change-me
STORAGE_S3_SECRET_KEY=change-me
STORAGE_S3_ENDPOINT=change-me
STORAGE_S3_REGION=us-east-1

# ─── Delivery ────────────────────────────────────────────
DELIVERY_BACKENDS=local
DELIVERY_LOCAL_PATH=./outputs
DELIVERY_S3_BUCKET=change-me
DELIVERY_S3_ACCESS_KEY=change-me
DELIVERY_S3_SECRET_KEY=change-me
DELIVERY_S3_ENDPOINT=change-me
DELIVERY_S3_REGION=us-east-1
DELIVERY_WEBHOOK_URL=change-me
DELIVERY_WEBHOOK_SECRET=change-me

# ─── Celery ──────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_ACKS_LATE=true
CELERY_TASK_REJECT_ON_WORKER_LOST=true
CELERY_TASK_RETRY_MAX=3
CELERY_TASK_RETRY_DELAY=30

# ─── Product Localization ─────────────────────────────────
EXTRACTOR_DEFAULT_LANGUAGE=en
EXTRACTOR_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
EXTRACTOR_TIMEOUT=30

# ─── Smoke Test / Verification ───────────────────────────
SMOKE_TEST_MODE=false
SMOKE_MAX_TEXT_CALLS=1
SMOKE_MAX_IMAGE_CALLS=1
SMOKE_MAX_RETRIES=1
SMOKE_MAX_COST_CENTS=50
SMOKE_USE_CHEAPEST_MODEL=true

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT=stdout
